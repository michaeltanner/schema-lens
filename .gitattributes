# Handle line endings automatically for files detected as text
# and leave binary files untouched.
* text=auto

# Force LF on all text files (standard for GitHub and cross-platform dev)
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.xsd text eol=lf

# Explicitly mark binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
